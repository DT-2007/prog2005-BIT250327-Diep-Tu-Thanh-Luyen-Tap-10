   "source": [
    "def giai_thua(n):\n",
    "    if n == 0 or n == 1:\n",
    "        return 1\n",
    "    return n * giai_thua(n - 1)\n",
    "\n",
    "n = int(input(\"Nhập n: \"))\n",
    "print(\"Giai thừa:\", giai_thua(n))"
   ],
