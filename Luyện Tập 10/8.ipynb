   "source": [
    "arr = []\n",
    "\n",
    "for i in range(5):\n",
    "    arr.append(input(f\"Chuỗi {i+1}: \"))\n",
    "\n",
    "n = len(arr)\n",
    "\n",
    "for i in range(n):\n",
    "    for j in range(0, n-i-1):\n",
    "        if len(arr[j]) < len(arr[j+1]):\n",
    "            arr[j], arr[j+1] = arr[j+1], arr[j]\n",
    "\n",
    "        print(\"Bước:\", arr)\n",
    "\n",
    "print(\"Kết quả:\", arr)"
   ],
