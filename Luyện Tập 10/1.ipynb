   "source": [
    "def lay_ten_file(path):\n",
    "    return path.split(\"\\\\\")[-1]\n",
    "\n",
    "def lay_ten_khong_duoi(path):\n",
    "    ten_file = lay_ten_file(path)\n",
    "    return ten_file.split(\".\")[0]\n",
    "\n",
    "# Test\n",
    "p = \"d:\\\\music\\\\AiKhocNoiDauNay.mp3\"\n",
    "print(lay_ten_file(p))\n",
    "print(lay_ten_khong_duoi(p))"
   ],
